rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Properties: Anyone can read, only authenticated admin can create/update/delete
    match /properties/{propertyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Leads: Anyone can create (submit form), only authenticated admin can read/update/delete
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
